# Environment variables - DO NOT COMMIT
.env
.env.local
.env.*.local
.env.production
.env.development

# Security - DO NOT COMMIT
# config.py is intentionally NOT listed here: it contains no secrets,
# only reads from os.environ via load_dotenv().  It must be tracked so
# that anyone who clones the repo gets a working configuration module.
# Real secrets (SECRET_KEY, ADMIN_PASSWORD_KEY, MAIL_PASSWORD, etc.)
# live in .env, which IS listed above.
api_keys.py
secrets/
*secret*
*password*
*token*

